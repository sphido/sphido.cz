{
	"private": true,
	"author": "Roman Ožana <roman@ozana.cz> (https://ozana.cz)",
	"license": "MIT",
	"repository": "sphido/sphido.cz",
	"type": "module",
	"scripts": {
		"build": "pnpm run build:html && pnpm run build:css",
		"build:html": "node index.js",
		"build:css": "tailwindcss -i ./src/sphido.css -o ./public/sphido.css",
		"css": "tailwindcss -i ./src/sphido.css -o ./public/sphido.css --watch",
		"dev": "nodemon --watch content --watch src --ext md,js,css,latte --exec \"pnpm run build\" | serve public",
		"serve": "serve public",
		"format": "biome format --write",
		"deploy": "gh-pages -d public"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@sindresorhus/slugify": "^3.0.0",
		"@sphido/core": "^3.0.0",
		"@sphido/sitemap": "^3.0.1",
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/typography": "^0.5.19",
		"gh-pages": "^6.3.0",
		"globby": "^16.2.0",
		"got": "^15.0.0",
		"nodemon": "^3.1.14",
		"prismjs": "^1.30.0",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-html": "^16.0.1",
		"serve": "^14.2.6",
		"tailwindcss": "^4.2.2",
		"unist-util-visit": "^5.1.0"
	}
}
